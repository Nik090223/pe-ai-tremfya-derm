# IDE
# Track shared VS Code config (settings/launch/extensions) so the repo
# is turnkey for collaborators. Ignore only personal/local overrides.
.vscode/*.local.json
.vscode/*.code-workspace
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Docker / k8s local
*.tar
kubeconfig
